<resources>
    <style name="CarCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">12dp</item>
        <item name="android:background">#E8EAF6</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <style name="CarTitle">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#1F618D</item>
    </style>

    <style name="CarDetail">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#566573</item>
    </style>

    <style name="RentButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:backgroundTint">#1F618D</item>
        <item name="android:textColor">@android:color/white</item>
    </style>
</resources>
